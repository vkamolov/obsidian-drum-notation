{
  "name": "obsidian-drum-notation",
  "version": "0.9.3",
  "description": "Render and play drum kit notation blocks in Obsidian notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "typecheck:watch": "tsc -noEmit -skipLibCheck --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "web": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "web:typecheck": "tsc -p web/tsconfig.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "drums",
    "notation"
  ],
  "author": "vkamolov",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.0",
    "vite": "^6.4.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "vexflow": "^5.0.0"
  }
}
